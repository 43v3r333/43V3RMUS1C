# ===============================================
# 43V3R CORE - Environment Configuration
# ===============================================

# Application
APP_NAME=43v3r-core
APP_VERSION=1.0.0
APP_ENV=development

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_DEBUG=true

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=versemusic
POSTGRES_USER=versemusic
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# Celery
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/2

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:13000

# File Storage
STORAGE_TYPE=local
STORAGE_PATH=/app/storage
MEDIA_PATH=/app/storage/media
ASSETS_PATH=/app/storage/assets
TEMP_PATH=/app/storage/temp

# FFmpeg
FFMPEG_PATH=/usr/bin/ffmpeg
FFMPEG_TIMEOUT=3600

# External Services (placeholders)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=90

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json